{
  "name": "fruit-mandi-api",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create fruit-mandi",
    "db:migrate": "wrangler d1 execute fruit-mandi --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute fruit-mandi --local --file=./schema.sql",
    "vectorize:create": "wrangler vectorize create fruit-mandi-index --dimensions=1536 --metric=cosine"
  },
  "devDependencies": {
    "wrangler": "^3.99.0"
  }
}
