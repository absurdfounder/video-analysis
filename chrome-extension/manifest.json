{
  "manifest_version": 3,
  "name": "Fruit Price Transcript Miner",
  "version": "1.6.0",
  "description": "Pull YouTube captions from your browser session and extract timestamped fruit price rows.",
  "action": {
    "default_title": "Open Delhi Fruit Market Miner"
  },
  "side_panel": {
    "default_path": "index.html?mode=sidepanel"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtu.be/*",
    "https://*.googlevideo.com/*",
    "https://api.openai.com/*",
    "https://*.netlify.app/*",
    "https://*.workers.dev/*",
    "http://localhost/*"
  ]
}
